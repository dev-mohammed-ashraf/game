import React, { useState, useEffect, useRef } from 'react';
import * as THREE from 'three';
import { ArrowUp, ArrowDown, ArrowLeft, ArrowRight, Pickaxe, Sparkles, Star, RefreshCcw, Trophy, ChevronRight } from 'lucide-react';

const App = () => {
  const mountRef = useRef(null);
  const [gameState, setGameState] = useState('intro'); // intro, playing, levelSuccess, gameComplete
  const [level, setLevel] = useState(1);
  const [canBuild, setCanBuild] = useState(false);
  
  // Three.js Refs
  const sceneRef = useRef(null);
  const rabbitRef = useRef(null);
  const rendererRef = useRef(null);
  const bridgeBlocksRef = useRef([]);
  const ghostBlocksRef = useRef([]); // Visual hints
  const targetPos = useRef(new THREE.Vector3(0, 0.5, 0));
  const audioCtx = useRef(null);

  const levelData = {
    1: { waterX: [4, 5, 6], starPos: { x: 10, z: 0 }, startPos: { x: 0, z: 0 } },
    2: { waterX: [3, 4, 8, 9], starPos: { x: 12, z: 2 }, startPos: { x: -2, z: 0 } },
    3: { waterX: [2, 3, 6, 7, 10, 11], starPos: { x: 14, z: -2 }, startPos: { x: -4, z: 0 } }
  };

  // --- Audio Engine ---
  const initAudio = () => {
    if (!audioCtx.current) {
      audioCtx.current = new (window.AudioContext || window.webkitAudioContext)();
    }
  };

  const playSound = (type) => {
    initAudio();
    const ctx = audioCtx.current;
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain);
    gain.connect(ctx.destination);

    if (type === 'move') {
      osc.frequency.setValueAtTime(150, ctx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(40, ctx.currentTime + 0.1);
      gain.gain.setValueAtTime(0.05, ctx.currentTime);
      osc.start();
      osc.stop(ctx.currentTime + 0.1);
    } else if (type === 'alert') {
      // Sound when build button appears (Ding-dong)
      osc.type = 'triangle';
      osc.frequency.setValueAtTime(440, ctx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(880, ctx.currentTime + 0.2);
      gain.gain.setValueAtTime(0.1, ctx.currentTime);
      osc.start();
      osc.stop(ctx.currentTime + 0.2);
    } else if (type === 'win') {
      // Success Arpeggio
      const notes = [523.25, 659.25, 783.99, 1046.50];
      notes.forEach((freq, i) => {
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.frequency.value = freq;
        g.gain.setValueAtTime(0, ctx.currentTime + i * 0.1);
        g.gain.linearRampToValueAtTime(0.1, ctx.currentTime + i * 0.1 + 0.05);
        g.gain.linearRampToValueAtTime(0, ctx.currentTime + i * 0.1 + 0.3);
        o.connect(g);
        g.connect(ctx.destination);
        o.start(ctx.currentTime + i * 0.1);
        o.stop(ctx.currentTime + i * 0.1 + 0.4);
      });
    }
  };

  useEffect(() => {
    if (gameState === 'intro' || gameState === 'gameComplete') return;

    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0xa7f3d0); // Mint Sky
    scene.fog = new THREE.Fog(0xa7f3d0, 8, 25);
    sceneRef.current = scene;

    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.shadowMap.enabled = true;
    rendererRef.current = renderer;
    mountRef.current.appendChild(renderer.domElement);

    // Lights
    scene.add(new THREE.AmbientLight(0xffffff, 0.7));
    const dirLight = new THREE.DirectionalLight(0xffffff, 0.9);
    dirLight.position.set(10, 20, 10);
    dirLight.castShadow = true;
    scene.add(dirLight);

    // World
    const boxGeo = new THREE.BoxGeometry(1, 1, 1);
    const grassMat = new THREE.MeshStandardMaterial({ color: 0x4ade80 });
    const waterMat = new THREE.MeshStandardMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.6 });
    const dirtMat = new THREE.MeshStandardMaterial({ color: 0x92400e });

    const currentLvl = levelData[level];
    bridgeBlocksRef.current = [];
    ghostBlocksRef.current = [];
    targetPos.current.set(currentLvl.startPos.x, 0.5, currentLvl.startPos.z);

    for (let x = -10; x < 25; x++) {
      for (let z = -5; z < 5; z++) {
        const isWater = currentLvl.waterX.includes(x);
        const block = new THREE.Mesh(boxGeo, isWater ? waterMat : (x < 0 ? dirtMat : grassMat));
        block.position.set(x, isWater ? -0.8 : -0.5, z);
        block.receiveShadow = true;
        scene.add(block);
        
        // Add Ghost Bridge (Visual Hint for children)
        if (isWater) {
          const ghostGeo = new THREE.BoxGeometry(0.8, 0.1, 0.8);
          const ghostMat = new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.2, wireframe: true });
          const ghost = new THREE.Mesh(ghostGeo, ghostMat);
          ghost.position.set(x, -0.2, z);
          ghost.visible = false; // Hide initially
          scene.add(ghost);
          ghostBlocksRef.current.push({ x, z, mesh: ghost });
        }
      }
    }

    // Goal Star
    const star = new THREE.Mesh(
      new THREE.OctahedronGeometry(0.5, 0),
      new THREE.MeshStandardMaterial({ color: 0xffd700, emissive: 0xffaa00 })
    );
    star.position.set(currentLvl.starPos.x, 1.2, currentLvl.starPos.z);
    scene.add(star);

    // Rabbit Model
    const rabbit = new THREE.Group();
    const whiteMat = new THREE.MeshStandardMaterial({ color: 0xffffff });
    const pinkMat = new THREE.MeshStandardMaterial({ color: 0xffb6c1 });

    const body = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.5, 0.7), whiteMat);
    body.position.y = 0.25;
    body.castShadow = true;
    rabbit.add(body);

    const head = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.4, 0.4), whiteMat);
    head.position.set(0, 0.6, 0.2);
    rabbit.add(head);

    const earGeo = new THREE.BoxGeometry(0.1, 0.4, 0.1);
    const ear1 = new THREE.Mesh(earGeo, whiteMat);
    ear1.position.set(0.12, 0.9, 0.2);
    rabbit.add(ear1);
    const ear2 = new THREE.Mesh(earGeo, whiteMat);
    ear2.position.set(-0.12, 0.9, 0.2);
    rabbit.add(ear2);

    rabbit.position.copy(targetPos.current);
    scene.add(rabbit);
    rabbitRef.current = rabbit;

    const animate = () => {
      if (!rendererRef.current) return;
      requestAnimationFrame(animate);
      
      star.rotation.y += 0.05;
      
      if (rabbitRef.current) {
        rabbitRef.current.position.lerp(targetPos.current, 0.15);
        
        // Fixed Camera Follow (Behind character)
        const cameraOffset = new THREE.Vector3(-6, 6, 0);
        camera.position.lerp(new THREE.Vector3().copy(rabbitRef.current.position).add(cameraOffset), 0.1);
        camera.lookAt(rabbitRef.current.position.x + 2, 1, rabbitRef.current.position.z);
      }

      rendererRef.current.render(scene, camera);
    };
    animate();

    return () => {
      if (mountRef.current && renderer.domElement) mountRef.current.removeChild(renderer.domElement);
      renderer.dispose();
    };
  }, [gameState, level]);

  const handleInput = (dx, dz) => {
    if (gameState !== 'playing') return;
    playSound('move');
    
    const currentLvl = levelData[level];
    const newX = targetPos.current.x + dx;
    const newZ = targetPos.current.z + dz;

    const isOverWater = currentLvl.waterX.some(wx => Math.abs(newX - wx) < 0.4);
    const hasBridge = bridgeBlocksRef.current.some(b => 
      Math.abs(b.position.x - Math.round(newX)) < 0.3 && Math.abs(b.position.z - Math.round(newZ)) < 0.3
    );

    if (isOverWater && !hasBridge) {
      if (!canBuild) {
        playSound('alert');
        setCanBuild(true);
        // Show visual hints (ghost blocks) near player
        ghostBlocksRef.current.forEach(g => {
          if (Math.abs(g.x - newX) < 3) g.mesh.visible = true;
        });
      }
      return;
    }

    targetPos.current.set(newX, 0.5, newZ);
    if (rabbitRef.current) {
        rabbitRef.current.rotation.y = Math.atan2(-dz, dx);
    }

    const dist = Math.sqrt(Math.pow(newX - currentLvl.starPos.x, 2) + Math.pow(newZ - currentLvl.starPos.z, 2));
    if (dist < 0.8) {
      playSound('win');
      setGameState(level < 3 ? 'levelSuccess' : 'gameComplete');
    }
  };

  const build = () => {
    if (!rabbitRef.current) return;
    const bX = Math.round(targetPos.current.x + 1);
    const bZ = Math.round(targetPos.current.z);
    
    if (levelData[level].waterX.includes(bX)) {
      const block = new THREE.Mesh(new THREE.BoxGeometry(0.95, 0.3, 0.95), new THREE.MeshStandardMaterial({ color: 0xd97706 }));
      block.position.set(bX, -0.15, bZ);
      sceneRef.current.add(block);
      bridgeBlocksRef.current.push(block);
      
      // Hide the ghost block we just built over
      const ghost = ghostBlocksRef.current.find(g => g.x === bX && g.z === bZ);
      if (ghost) ghost.mesh.visible = false;
      
      playSound('move');
    }
  };

  useEffect(() => {
    const onKey = (e) => {
      if (e.key === 'ArrowUp') handleInput(1, 0);
      if (e.key === 'ArrowDown') handleInput(-1, 0);
      if (e.key === 'ArrowLeft') handleInput(0, -1);
      if (e.key === 'ArrowRight') handleInput(0, 1);
    };
    window.addEventListener('keydown', onKey);
    return () => window.removeEventListener('keydown', onKey);
  }, [gameState, level, canBuild]);

  return (
    <div className="relative w-full h-screen overflow-hidden bg-emerald-50" dir="rtl">
      <div ref={mountRef} className="absolute inset-0" />

      {/* Visual UI for Kid */}
      <div className="absolute inset-0 pointer-events-none p-6 flex flex-col items-center font-sans">
        
        {/* Simple Progress Header */}
        <div className="w-full max-w-xl flex justify-between items-center bg-white/90 backdrop-blur p-4 rounded-[2rem] shadow-xl pointer-events-auto border-b-4 border-emerald-400">
          <div className="flex items-center gap-3">
             <div className="bg-yellow-400 p-2 rounded-full shadow-md"><Star size={24} className="text-white fill-current"/></div>
             <div className="flex gap-1">
               {[1, 2, 3].map(i => (
                 <div key={i} className={`w-8 h-3 rounded-full ${i <= level ? 'bg-emerald-500' : 'bg-gray-200'}`} />
               ))}
             </div>
          </div>
          <div className="text-emerald-700 font-black text-xl">
             مغامرة الأرنب
          </div>
        </div>

        {/* States Overlays */}
        {gameState === 'intro' && (
          <div className="absolute inset-0 z-50 bg-emerald-500 flex flex-col items-center justify-center text-white pointer-events-auto">
             <div className="bg-white p-10 rounded-[4rem] shadow-2xl mb-10 animate-bounce">
                <Star size={120} className="text-yellow-400 fill-current"/>
             </div>
             <h2 className="text-6xl font-black mb-12 drop-shadow-lg">هيا نلعب!</h2>
             <button 
              onClick={() => { initAudio(); setGameState('playing'); }} 
              className="bg-yellow-400 text-emerald-900 font-black py-6 px-24 rounded-full text-5xl shadow-[0_12px_0_rgb(180,130,0)] active:translate-y-2 active:shadow-none transition-all"
             >
                ابدأ
             </button>
          </div>
        )}

        {gameState === 'levelSuccess' && (
          <div className="absolute inset-0 z-50 bg-black/40 backdrop-blur flex items-center justify-center pointer-events-auto">
             <div className="bg-white p-12 rounded-[4rem] text-center shadow-2xl border-8 border-yellow-400 scale-110">
                <Trophy size={120} className="text-yellow-400 mx-auto mb-6 drop-shadow-xl animate-pulse" />
                <h2 className="text-5xl font-black text-gray-800 mb-10">أنت بطل!</h2>
                <button 
                  onClick={() => {setLevel(l => l+1); setGameState('playing'); setCanBuild(false);}} 
                  className="bg-emerald-500 text-white font-black py-6 px-16 rounded-full text-3xl flex items-center gap-3 hover:scale-105 transition-transform"
                >
                  التالي <ChevronRight size={40}/>
                </button>
             </div>
          </div>
        )}

        {gameState === 'gameComplete' && (
          <div className="absolute inset-0 z-50 bg-emerald-600 flex flex-col items-center justify-center text-white pointer-events-auto text-center p-6">
             <Star size={150} className="text-yellow-300 fill-current mb-8 animate-spin" />
             <h2 className="text-7xl font-black mb-6">عبقري!</h2>
             <p className="text-3xl mb-12 font-bold">لقد فزت في كل المستويات</p>
             <button onClick={() => window.location.reload()} className="bg-white text-emerald-600 font-black py-6 px-20 rounded-full text-3xl shadow-2xl">العب مجدداً</button>
          </div>
        )}

        {/* Action Controls */}
        <div className="mt-auto w-full max-w-3xl flex justify-between items-end pb-12 pointer-events-auto px-4">
          <div className="w-48">
            {canBuild && (
              <button 
                onClick={build} 
                className="bg-orange-500 rounded-[2.5rem] shadow-[0_12px_0_rgb(150,50,0)] flex flex-col items-center justify-center text-white border-4 border-white active:translate-y-2 active:shadow-none animate-bounce p-6 w-full"
              >
                <Pickaxe size={54} />
                <span className="font-black text-xl mt-2 whitespace-nowrap">ابنِ جسراً للمرور</span>
              </button>
            )}
          </div>

          <div className="grid grid-cols-3 gap-4 bg-white/50 p-6 rounded-[3rem] backdrop-blur-md shadow-2xl border-2 border-white/50">
             <div/>
             <button onPointerDown={() => handleInput(1,0)} className="w-20 h-20 bg-white rounded-3xl shadow-lg flex items-center justify-center active:scale-90 transition-transform"><ArrowUp className="text-emerald-600" size={48}/></button>
             <div/>
             <button onPointerDown={() => handleInput(0,-1)} className="w-20 h-20 bg-white rounded-3xl shadow-lg flex items-center justify-center active:scale-90 transition-transform"><ArrowLeft className="text-emerald-600" size={48}/></button>
             <button onPointerDown={() => handleInput(-1,0)} className="w-20 h-20 bg-white rounded-3xl shadow-lg flex items-center justify-center active:scale-90 transition-transform"><ArrowDown className="text-emerald-600" size={48}/></button>
             <button onPointerDown={() => handleInput(0,1)} className="w-20 h-20 bg-white rounded-3xl shadow-lg flex items-center justify-center active:scale-90 transition-transform"><ArrowRight className="text-emerald-600" size={48}/></button>
          </div>
        </div>
      </div>

      <style>{`
        canvas { touch-action: none; outline: none; }
        body { user-select: none; }
        .font-sans { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
      `}</style>
    </div>
  );
};

export default App;
